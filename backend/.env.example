## API key - any browser/proxy must send X-LOGPOSE-KEY matching this.
## Leave empty during local dev to disable auth.
LOGPOSE_API_KEY=

## Gemini 2.5 Flash for the Marine Verifier.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

## Crew service (for proactive nudges over webhook).
CREW_URL=http://logpose-crew:8325
CREW_INTERNAL_KEY=

## Log Pose rollover (local time).
ROLLOVER_HOUR=4
ROLLOVER_MINUTE=0
LOGPOSE_TZ=Asia/Kolkata

## SQLite path (inside container).
DB_PATH=/app/data/bounty.db
MEDIA_DIR=/app/data/media

## CORS origins for direct-browser dev access. UI proxy doesn't need this.
CORS_ORIGINS=http://localhost:3005
