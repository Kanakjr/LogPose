## API key - the UI middleware injects X-LOGPOSE-CREW-KEY matching this.
LOGPOSE_CREW_KEY=

## Separate internal key the game backend uses to fire /api/crew/event.
CREW_INTERNAL_KEY=

## Gemini for crewmate replies.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

## Upstream game backend - the crew calls this read-only for Captain state.
GAME_BACKEND_URL=http://logpose-backend:8324
LOGPOSE_API_KEY=

## Personal data sources (read-only mounts).
OBSIDIAN_VAULT_PATH=/app/obsidian
HUBERMAN_CODEX_PATH=/app/data/huberman

## Nudge cooldowns.
MAX_NUDGES_PER_DAY=3
COOLDOWN_PER_CREWMATE_SEC=21600

## Local timezone.
LOGPOSE_TZ=Asia/Kolkata

## Storage.
DB_PATH=/app/data/crew.db

## CORS origins for direct browser dev.
CORS_ORIGINS=http://localhost:3005
