# LogPose - shared environment.
# Copy to .env and fill in the values, then `docker compose up -d --build`.

# Google Gemini key. Required for Marine Verifier (Gemini Vision) and crew chat.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Browser <-> backend auth. The UI proxy injects this as X-LOGPOSE-KEY.
# Generate with: openssl rand -hex 32
LOGPOSE_API_KEY=

# Browser <-> crew service auth. The UI proxy injects this as X-LOGPOSE-CREW-KEY.
LOGPOSE_CREW_KEY=

# Backend <-> crew service internal webhook auth.
LOGPOSE_CREW_INTERNAL_KEY=

# Local time used for daily rollover and journal timestamps.
TZ=Asia/Kolkata
LOGPOSE_ROLLOVER_HOUR=4

# Optional: absolute host path to your Obsidian vault. Mounted read-only into
# the crew container so Robin / Chopper can cite your notes. Leave unset to
# disable.
# OBSIDIAN_VAULT_PATH=/Users/you/Documents/Obsidian
